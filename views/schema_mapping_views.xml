<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_midvex_schema_mapping_form" model="ir.ui.view">
        <field name="name">midvex.schema.mapping.form</field>
        <field name="model">midvex.schema.mapping</field>
        <field name="arch" type="xml">
            <form string="Schema Mapping">
                <header>
                    <button name="action_load_template_fields" string="Generate Lines from Template" type="object" class="btn-primary"/>
                    <button name="action_load_sample_mapping" string="Load Sample Mapping" type="object" class="btn-secondary"/>
                    <button string="Import / Export" type="action"
                            name="%(action_midvex_schema_config_transfer_wizard)d"
                            class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Map whitelisted Odoo fields or safe tokens into schema dot-paths. No Python expressions are evaluated.
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="target_model_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="schema_template_id" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="line_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="schema_field_path"/>
                            <field name="source_type"/>
                            <field name="token" placeholder="{{ product.name }}"/>
                            <field name="odoo_field_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="default_value"/>
                            <field name="field_type"/>
                            <field name="required"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_midvex_schema_mapping_list" model="ir.ui.view">
        <field name="name">midvex.schema.mapping.list</field>
        <field name="model">midvex.schema.mapping</field>
        <field name="arch" type="xml">
            <list string="Model-to-Schema Mappings">
                <field name="name"/>
                <field name="target_model_id"/>
                <field name="schema_template_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_midvex_schema_mapping" model="ir.actions.act_window">
        <field name="name">Model Mappings</field>
        <field name="res_model">midvex.schema.mapping</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
