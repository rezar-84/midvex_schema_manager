<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Form view ───────────────────────────────────────────────────── -->
    <record id="view_midvex_schema_record_form" model="ir.ui.view">
        <field name="name">midvex.schema.record.form</field>
        <field name="model">midvex.schema.record</field>
        <field name="arch" type="xml">
            <form string="Page Schema">
                <header>
                    <button string="Validate" name="action_validate"
                            type="object" class="btn-primary"/>
                    <button string="Generate Preview" name="action_generate_json"
                            type="object"/>
                    <button string="Auto-populate" name="action_auto_populate"
                            type="object"
                            invisible="not auto_populate or target_type not in ('page',)"/>
                    <button string="Add Required Fields" name="action_add_required_fields"
                            type="object" invisible="not schema_template_id"/>
                    <button string="Add Optional Fields" name="action_add_optional_fields"
                            type="object" invisible="not schema_template_id"/>
                    <button string="Reset Fields from Template" name="action_reset_fields_from_template"
                            type="object" invisible="not schema_template_id" confirm="This will replace all field rows from the selected template. Continue?"/>
                    <button string="Create for All Languages" name="action_open_lang_wizard"
                            type="object" class="btn-secondary"/>
                    <field name="validation_status" widget="statusbar"
                           statusbar_visible="draft,valid,warning,error"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button"
                                type="object"
                                name="action_open_rich_results_test"
                                icon="fa-search"
                                invisible="not target_url">
                            <span class="o_stat_text">Rich Results Test</span>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="Archived"
                            bg_color="bg-danger" invisible="active"/>

                    <div class="alert alert-success" role="alert" invisible="validation_status != 'valid'">
                        Valid schema. This record is ready to render when Active is enabled.
                    </div>
                    <div class="alert alert-warning" role="alert" invisible="validation_status != 'warning'">
                        <field name="validation_message" readonly="1" nolabel="1"/>
                    </div>
                    <div class="alert alert-danger" role="alert" invisible="validation_status != 'error'">
                        <field name="validation_message" readonly="1" nolabel="1"/>
                    </div>
                    <div class="alert alert-info" role="alert" invisible="validation_status != 'draft'">
                        Draft schema. Select a template, fill the required fields, then validate.
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Schema Record Name"/></h1>
                    </div>

                    <group>
                        <group>
                            <field name="schema_template_id"
                                   placeholder="Start with Product, FAQPage, BreadcrumbList, Article, Service..."/>
                            <field name="schema_type" readonly="schema_template_id"/>
                            <field name="website_id"/>
                            <field name="lang_code" placeholder="en"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="priority"/>
                            <field name="validation_status" readonly="1"/>
                            <field name="auto_populate"/>
                            <field name="duplicate_warning" readonly="1"
                                   invisible="not duplicate_warning"/>
                        </group>
                    </group>

                    <group string="Render Target">
                        <div class="alert alert-info" role="alert" invisible="target_type != 'global'">
                            Rendered on all pages. Use rarely; global Organization/WebSite is usually handled by Global Website Schema.
                        </div>
                        <div class="alert alert-info" role="alert" invisible="target_type != 'page'">
                            Attach this schema to a specific Odoo website page.
                        </div>
                        <div class="alert alert-info" role="alert" invisible="target_type != 'url'">
                            Render URL / Target URL controls where the schema is rendered. It is different from the Schema URL field inside JSON-LD.
                        </div>
                        <group>
                            <field name="target_type" widget="radio" options="{'horizontal': true}"/>
                            <field name="website_page_id"
                                   invisible="target_type != 'page'"
                                   required="target_type == 'page'"/>
                            <field name="target_url"
                                   invisible="target_type == 'global'"
                                   placeholder="/page-url, /tr/page-url, or https://example.com/page-url"/>
                        </group>
                        <group>
                            <field name="render_target_summary" readonly="1"/>
                            <field name="resolved_url_preview" readonly="1"/>
                        </group>
                    </group>

                    <notebook>

                        <!-- FAQ first when the selected schema uses FAQ lines -->
                        <page string="FAQ Items" name="faq_items" invisible="schema_type != 'FAQPage'">
                            <div class="alert alert-warning" role="alert">
                                FAQ schema should only be used when the same FAQs are visible on the page.
                            </div>
                            <button string="Add FAQ Item" name="action_add_sample_faq"
                                    type="object" class="btn-secondary mb-2"/>
                            <field name="faq_item_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="position" widget="handle"/>
                                    <field name="question"/>
                                    <field name="answer"/>
                                    <field name="active" optional="show"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="question"/>
                                        <field name="answer" widget="text"/>
                                        <field name="position"/>
                                        <field name="active"/>
                                    </group>
                                </form>
                            </field>
                        </page>

                        <page string="Breadcrumb Items" name="breadcrumb_items" invisible="schema_type != 'BreadcrumbList'">
                            <div class="alert alert-info" role="alert">
                                Suggest breadcrumbs from the render URL, then adjust names and URLs as needed. Positions must be sequential starting from 1.
                            </div>
                            <button string="Suggest Breadcrumbs from URL" name="action_suggest_breadcrumbs"
                                    type="object" class="btn-secondary mb-2"/>
                            <field name="breadcrumb_item_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="position" widget="handle"/>
                                    <field name="name"/>
                                    <field name="url"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="name"/>
                                        <field name="url"/>
                                        <field name="position"/>
                                    </group>
                                </form>
                            </field>
                        </page>

                        <!-- Tab 1 — Field Values -->
                        <page string="Fields" name="field_values" invisible="schema_type == 'FAQPage'">
                            <div class="alert alert-info" role="alert">
                                Use Label and Value for normal editing. Field Key is for advanced JSON-LD mapping. The Schema URL / Canonical URL value is the URL inside JSON-LD, not the render target.
                            </div>
                            <field name="field_value_ids" nolabel="1">
                                <list editable="bottom" optional="show">
                                    <field name="sequence" widget="handle"/>
                                    <field name="field_label"/>
                                    <field name="field_key"/>
                                    <field name="field_type"/>
                                    <field name="required"/>
                                    <field name="value_char"
                                           invisible="field_type not in ('char',)"
                                           optional="show"/>
                                    <field name="value_text"
                                           invisible="field_type not in ('text',)"
                                           optional="hide"/>
                                    <field name="value_url"
                                           invisible="field_type not in ('url',)"
                                           optional="show"/>
                                    <field name="value_boolean"
                                           invisible="field_type not in ('boolean',)"
                                           optional="hide"/>
                                    <field name="value_integer"
                                           invisible="field_type not in ('integer',)"
                                           optional="hide"/>
                                    <field name="value_float"
                                           invisible="field_type not in ('float',)"
                                           optional="hide"/>
                                    <field name="value_json"
                                           invisible="field_type not in ('json',)"
                                           optional="hide"/>
                                </list>
                                <form>
                                    <group>
                                        <group>
                                            <field name="field_label"/>
                                            <field name="field_key"/>
                                            <field name="field_type"/>
                                            <field name="required"/>
                                            <field name="sequence"/>
                                        </group>
                                        <group>
                                            <field name="value_char"
                                                   invisible="field_type not in ('char',)"/>
                                            <field name="value_text"
                                                   invisible="field_type not in ('text',)"/>
                                            <field name="value_url"
                                                   invisible="field_type not in ('url',)"/>
                                            <field name="value_html"
                                                   invisible="field_type not in ('html',)"/>
                                            <field name="value_json"
                                                   invisible="field_type not in ('json',)"
                                                   widget="text"/>
                                            <field name="value_boolean"
                                                   invisible="field_type not in ('boolean',)"/>
                                            <field name="value_integer"
                                                   invisible="field_type not in ('integer',)"/>
                                            <field name="value_float"
                                                   invisible="field_type not in ('float',)"/>
                                        </group>
                                    </group>
                                </form>
                            </field>
                        </page>

                        <!-- Tab 5 — JSON Preview -->
                        <page string="JSON Preview" name="json_preview">
                            <group string="Generated JSON">
                                <field name="generated_json" nolabel="1"
                                       readonly="1" widget="text"/>
                            </group>
                            <group string="Generated HTML">
                                <field name="generated_html" nolabel="1"
                                       readonly="1" widget="text"/>
                            </group>
                        </page>

                        <!-- Tab 6 — Validation -->
                        <page string="Validation" name="validation">
                            <group>
                                <group>
                                    <field name="validation_status" readonly="1"/>
                                    <field name="last_generated_at" readonly="1"/>
                                </group>
                            </group>
                            <group string="Validation Message">
                                <field name="validation_message" nolabel="1"
                                       readonly="1" widget="text"/>
                            </group>
                            <div class="mt-2">
                                <button string="Open Schema Markup Validator"
                                        name="action_open_schema_validator"
                                        type="object"
                                        class="btn-secondary me-2"/>
                                <button string="Open Google Rich Results Test"
                                        name="action_open_rich_results_test"
                                        type="object"
                                        class="btn-secondary"
                                        invisible="not target_url"/>
                            </div>
                        </page>

                        <!-- Tab 6 — Manual JSON (managers only) -->
                        <page string="Advanced JSON Override" name="manual_json"
                              groups="midvex_schema_manager.group_midvex_schema_manager">
                            <div class="alert alert-warning" role="alert">
                                Use this only if you want to fully replace the generated schema. Field values, FAQ items and breadcrumbs will be ignored.
                            </div>
                            <group>
                                <field name="manual_json_enabled"/>
                            </group>
                            <group invisible="not manual_json_enabled"
                                   string="Manual JSON Override">
                                <div class="mb-2">
                                    <button string="Format JSON" name="action_format_manual_json"
                                            type="object" class="btn-secondary me-2"/>
                                    <button string="Validate JSON" name="action_validate_manual_json"
                                            type="object" class="btn-secondary"/>
                                </div>
                                <field name="manual_json" nolabel="1"
                                       widget="text"
                                       class="o_midvex_json_editor o_midvex_json_editor_large"
                                       placeholder='{"@context":"https://schema.org","@type":"WebPage","name":"Example"}'/>
                            </group>
                        </page>

                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Dashboard / Kanban view ─────────────────────────────────────── -->
    <record id="view_midvex_schema_record_kanban" model="ir.ui.view">
        <field name="name">midvex.schema.record.kanban</field>
        <field name="model">midvex.schema.record</field>
        <field name="arch" type="xml">
            <kanban default_group_by="validation_status">
                <field name="name"/>
                <field name="website_id"/>
                <field name="target_type"/>
                <field name="render_target_summary"/>
                <field name="schema_type"/>
                <field name="validation_status"/>
                <field name="active"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">
                            <div class="o_kanban_record_top">
                                <strong><field name="name"/></strong>
                                <span class="badge text-bg-secondary" t-if="!record.active.raw_value">Archived</span>
                            </div>
                            <div class="mt-1">
                                <span class="badge text-bg-info"><field name="schema_type"/></span>
                                <span class="badge text-bg-light ms-1"><field name="target_type"/></span>
                            </div>
                            <div class="text-muted mt-2"><field name="render_target_summary"/></div>
                            <div class="mt-2">
                                <field name="website_id"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ── List view ───────────────────────────────────────────────────── -->
    <record id="view_midvex_schema_record_list" model="ir.ui.view">
        <field name="name">midvex.schema.record.list</field>
        <field name="model">midvex.schema.record</field>
        <field name="arch" type="xml">
            <list string="Page Schemas" default_order="priority desc, name">
                <field name="name"/>
                <field name="website_id" optional="show"/>
                <field name="target_type"/>
                <field name="target_url" optional="show"/>
                <field name="render_target_summary" optional="hide"/>
                <field name="lang_code"/>
                <field name="schema_template_id" optional="show"/>
                <field name="schema_type"/>
                <field name="active" optional="show"/>
                <field name="validation_status"
                       decoration-success="validation_status == 'valid'"
                       decoration-warning="validation_status == 'warning'"
                       decoration-danger="validation_status == 'error'"
                       decoration-muted="validation_status == 'draft'"/>
                <field name="auto_populate" optional="hide"/>
                <field name="last_generated_at" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ── Search view ─────────────────────────────────────────────────── -->
    <record id="view_midvex_schema_record_search" model="ir.ui.view">
        <field name="name">midvex.schema.record.search</field>
        <field name="model">midvex.schema.record</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="schema_type"/>
                <field name="target_url"/>
                <field name="lang_code"/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <filter string="Archived" name="inactive" domain="[('active','=',False)]"/>
                <separator/>
                <filter string="Valid" name="valid" domain="[('validation_status','=','valid')]"/>
                <filter string="Needs Attention" name="needs_attention" domain="[('validation_status','in',('warning','error'))]"/>
                <filter string="Errors" name="errors" domain="[('validation_status','=','error')]"/>
                <filter string="Warnings" name="warnings" domain="[('validation_status','=','warning')]"/>
                <separator/>
                <filter string="Global" name="global" domain="[('target_type','=','global')]"/>
                <filter string="Page" name="page" domain="[('target_type','=','page')]"/>
                <filter string="Custom URL" name="url" domain="[('target_type','=','url')]"/>
                <separator/>
                <filter string="Group: Website" name="group_by_website" context="{'group_by':'website_id'}"/>
                <filter string="Group: Schema Type" name="group_by_type" context="{'group_by':'schema_type'}"/>
                <filter string="Group: Language" name="group_by_lang" context="{'group_by':'lang_code'}"/>
                <filter string="Group: Target Type" name="group_by_target" context="{'group_by':'target_type'}"/>
                <filter string="Group: Validation Status" name="group_by_status" context="{'group_by':'validation_status'}"/>
            </search>
        </field>
    </record>

    <!-- ── Action ──────────────────────────────────────────────────────── -->
    <record id="action_midvex_schema_record" model="ir.actions.act_window">
        <field name="name">Page Schemas</field>
        <field name="res_model">midvex.schema.record</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1, 'default_target_type': 'page'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create Page Schema
            </p>
            <p>Use Global Website Schema for Organization/WebSite schema. Use Page Schemas to add Product, FAQ, Breadcrumb, Article, Service or other JSON-LD schema to a specific website page or URL.</p>
            <p>Start by selecting a template, then choose Website Page or Custom URL and fill the required fields.</p>
        </field>
    </record>

    <record id="action_midvex_schema_dashboard" model="ir.actions.act_window">
        <field name="name">Structured Data Dashboard</field>
        <field name="res_model">midvex.schema.record</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_active': 1, 'search_default_group_by_status': 1, 'default_target_type': 'page'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Structured Data
            </p>
            <p>Workflow: configure Global Website Schema, create a Page Schema, select a template, attach it to a Website Page or Custom URL, fill fields, validate, preview, then render on the frontend.</p>
            <p>Use the Structured Data menu for Global Website Schema, Create Page Schema, Page Schemas, Template Library, Coverage Report, Batch Operations and Model Mappings.</p>
        </field>
    </record>

</odoo>
