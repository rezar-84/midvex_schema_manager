<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_midvex_schema_coverage_list" model="ir.ui.view">
        <field name="name">midvex.schema.coverage.report.list</field>
        <field name="model">midvex.schema.coverage.report</field>
        <field name="arch" type="xml">
            <list string="Structured Data Coverage" create="0" edit="0" delete="0">
                <button name="action_open_website_page" type="object"
                        string="Open Page" icon="fa-external-link"/>
                <button name="action_open_page_schemas" type="object"
                        string="Schemas" icon="fa-code"/>
                <field name="website_id"/>
                <field name="website_page_id"/>
                <field name="url"/>
                <field name="schema_types"/>
                <field name="validation_status"
                       decoration-success="validation_status == 'valid'"
                       decoration-warning="validation_status == 'warning'"
                       decoration-danger="validation_status == 'error'"
                       decoration-muted="validation_status in ('draft', 'missing')"/>
                <field name="needs_attention"/>
            </list>
        </field>
    </record>

    <record id="view_midvex_schema_coverage_kanban" model="ir.ui.view">
        <field name="name">midvex.schema.coverage.report.kanban</field>
        <field name="model">midvex.schema.coverage.report</field>
        <field name="arch" type="xml">
            <kanban default_group_by="validation_status">
                <field name="website_page_id"/>
                <field name="website_id"/>
                <field name="url"/>
                <field name="schema_types"/>
                <field name="validation_status"/>
                <field name="needs_attention"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">
                            <div class="o_kanban_record_top">
                                <strong><field name="website_page_id"/></strong>
                                <span class="badge text-bg-warning" t-if="record.needs_attention.raw_value">Needs attention</span>
                            </div>
                            <div class="text-muted mt-1"><field name="url"/></div>
                            <div class="mt-2">
                                <span class="badge text-bg-secondary"><field name="validation_status"/></span>
                                <span class="ms-1"><field name="schema_types"/></span>
                            </div>
                            <div class="mt-3">
                                <button name="action_open_website_page" type="object" string="Open Page" class="btn btn-secondary btn-sm"/>
                                <button name="action_open_page_schemas" type="object" string="Schemas" class="btn btn-primary btn-sm ms-1"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_midvex_schema_coverage_search" model="ir.ui.view">
        <field name="name">midvex.schema.coverage.report.search</field>
        <field name="model">midvex.schema.coverage.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="url"/>
                <field name="website_id"/>
                <filter string="Pages without schema" name="missing" domain="[('validation_status','=','missing')]"/>
                <filter string="Pages with errors" name="errors" domain="[('validation_status','=','error')]"/>
                <filter string="Pages with warnings" name="warnings" domain="[('validation_status','=','warning')]"/>
                <filter string="Needs attention" name="needs_attention" domain="[('needs_attention','=',True)]"/>
                <separator/>
                <filter string="Website" name="group_by_website" context="{'group_by':'website_id'}"/>
                <filter string="Status" name="group_by_status" context="{'group_by':'validation_status'}"/>
            </search>
        </field>
    </record>

    <record id="action_midvex_schema_coverage_report" model="ir.actions.act_window">
        <field name="name">Coverage Report</field>
        <field name="res_model">midvex.schema.coverage.report</field>
        <field name="view_mode">kanban,list</field>
        <field name="search_view_id" ref="view_midvex_schema_coverage_search"/>
    </record>

</odoo>
