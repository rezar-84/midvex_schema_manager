<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Form view ───────────────────────────────────────────────────── -->
    <record id="view_midvex_schema_settings_form" model="ir.ui.view">
        <field name="name">midvex.schema.settings.form</field>
        <field name="model">midvex.schema.settings</field>
        <field name="arch" type="xml">
            <form string="Global Website Schema">
                <header>
                    <button string="Validate" name="action_validate_global_schema"
                            type="object" class="btn-primary"/>
                    <field name="validation_status" widget="statusbar"
                           statusbar_visible="draft,valid,warning,error"/>
                </header>
                <sheet>
                    <div class="alert alert-success" role="alert" invisible="validation_status != 'valid'">
                        Global Website Schema is valid.
                    </div>
                    <div class="alert alert-warning" role="alert" invisible="validation_status != 'warning'">
                        <field name="validation_message" readonly="1" nolabel="1"/>
                    </div>
                    <div class="alert alert-danger" role="alert" invisible="validation_status != 'error'">
                        <field name="validation_message" readonly="1" nolabel="1"/>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="organization_name" placeholder="Organization Name"/>
                        </h1>
                    </div>

                    <notebook>

                        <!-- Settings tab -->
                        <page string="Settings" name="settings">
                            <group string="Organization">
                                <group>
                                    <field name="website_id"/>
                                    <field name="enable_global_schema"/>
                                    <field name="organization_name"/>
                                    <field name="legal_name"/>
                                    <field name="alternate_names"
                                           placeholder="Comma-separated alternate names"/>
                                </group>
                                <group>
                                    <field name="logo_url" widget="url"
                                           placeholder="https://…"/>
                                    <field name="website_url" widget="url"
                                           placeholder="https://…"/>
                                    <field name="default_image_url" widget="url"
                                           placeholder="https://…"/>
                                    <field name="available_language_codes"
                                           placeholder="en,no,de"/>
                                </group>
                            </group>

                            <group string="Contact Info">
                                <group>
                                    <field name="email" widget="email"/>
                                    <field name="phone"/>
                                </group>
                            </group>

                            <group string="Address">
                                <group>
                                    <field name="street_address"/>
                                    <field name="city"/>
                                    <field name="region"/>
                                </group>
                                <group>
                                    <field name="postal_code"/>
                                    <field name="country_code" placeholder="NO"/>
                                </group>
                            </group>

                            <group string="Social Links (Same As)">
                                <field name="same_as_links" nolabel="1" widget="text"
                                       placeholder="https://linkedin.com/company/…&#10;https://twitter.com/…"/>
                            </group>

                            <group string="Schema Options">
                                <group>
                                    <field name="enable_website_schema"/>
                                    <field name="enable_search_action"
                                           invisible="not enable_website_schema"/>
                                </group>
                            </group>
                        </page>

                        <!-- Preview tab -->
                        <page string="Preview" name="preview">
                            <div class="alert alert-info" role="alert">
                                This preview shows the JSON-LD that will be injected globally
                                on every page for the selected website. Save changes to refresh.
                            </div>
                            <group string="Generated Global Schema JSON">
                                <field name="global_schema_preview" nolabel="1"
                                       readonly="1" widget="text"/>
                            </group>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── List view ───────────────────────────────────────────────────── -->
    <record id="view_midvex_schema_settings_list" model="ir.ui.view">
        <field name="name">midvex.schema.settings.list</field>
        <field name="model">midvex.schema.settings</field>
        <field name="arch" type="xml">
            <list string="Global Schema Settings">
                <field name="website_id"/>
                <field name="organization_name"/>
                <field name="website_url"/>
                <field name="enable_global_schema"/>
                <field name="enable_website_schema"/>
                <field name="validation_status"
                       decoration-success="validation_status == 'valid'"
                       decoration-warning="validation_status == 'warning'"
                       decoration-danger="validation_status == 'error'"
                       decoration-muted="validation_status == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- ── Action ──────────────────────────────────────────────────────── -->
    <record id="action_midvex_schema_settings" model="ir.actions.act_window">
        <field name="name">Global Website Schema</field>
        <field name="res_model">midvex.schema.settings</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure global schema settings for your website.
            </p>
            <p>Create one settings record per website to define your
               Organization and WebSite schema.</p>
        </field>
    </record>

</odoo>
