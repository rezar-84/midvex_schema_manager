<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_midvex_schema_config_transfer_wizard_form" model="ir.ui.view">
        <field name="name">midvex.schema.config.transfer.wizard.form</field>
        <field name="model">midvex.schema.config.transfer.wizard</field>
        <field name="arch" type="xml">
            <form string="Import / Export Configs">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Export creates either one Excel workbook or a ZIP archive containing CSV files.
                        Import expects the same structure generated by this wizard.
                    </div>
                    <group>
                        <group>
                            <field name="operation" widget="radio"/>
                            <field name="file_format" widget="radio"/>
                        </group>
                        <group string="Configuration">
                            <field name="include_settings"/>
                            <field name="include_templates"/>
                            <field name="include_mappings"/>
                        </group>
                    </group>
                    <group string="Import" invisible="operation != 'import'">
                        <field name="import_file" filename="import_filename" required="operation == 'import'"/>
                        <field name="import_filename" invisible="1"/>
                    </group>
                    <group string="Export" invisible="not export_file">
                        <field name="export_file" filename="export_filename" readonly="1"/>
                        <field name="export_filename" invisible="1"/>
                    </group>
                    <group invisible="not message">
                        <field name="message" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_export" string="Export" type="object"
                            class="btn-primary" invisible="operation != 'export'"/>
                    <button name="action_import" string="Import" type="object"
                            class="btn-primary" invisible="operation != 'import'"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_midvex_schema_config_transfer_wizard" model="ir.actions.act_window">
        <field name="name">Import / Export Configs</field>
        <field name="res_model">midvex.schema.config.transfer.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
