<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_midvex_schema_lang_wizard_form" model="ir.ui.view">
        <field name="name">midvex.schema.lang.wizard.form</field>
        <field name="model">midvex.schema.lang.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Schema for Multiple Languages">
                <group>
                    <field name="schema_record_id" readonly="1"/>
                </group>
                <group string="Select Languages">
                    <field name="language_ids" nolabel="1"
                           widget="many2many_checkboxes"/>
                </group>
                <footer>
                    <button string="Create Language Copies" type="object"
                            name="action_create_for_languages" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
