<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_midvex_schema_page_wizard_form" model="ir.ui.view">
        <field name="name">midvex.schema.page.wizard.form</field>
        <field name="model">midvex.schema.page.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Page Schema">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Select a template first, then attach it to an Odoo website page or a custom URL.
                    </div>
                    <group>
                        <group>
                            <field name="website_id"/>
                            <field name="lang_code" placeholder="en"/>
                            <field name="schema_template_id"/>
                            <field name="target_type" widget="radio" options="{'horizontal': true}"/>
                        </group>
                        <group>
                            <field name="website_page_id"
                                   invisible="target_type != 'page'"
                                   required="target_type == 'page'"/>
                            <field name="target_url"
                                   invisible="target_type == 'global'"
                                   placeholder="/page-url or https://example.com/page-url"/>
                            <field name="add_optional_fields"/>
                            <field name="auto_populate"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Create Page Schema" name="action_create_schema" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_midvex_schema_page_wizard" model="ir.actions.act_window">
        <field name="name">Create Page Schema</field>
        <field name="res_model">midvex.schema.page.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
