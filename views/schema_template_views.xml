<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Form view ───────────────────────────────────────────────────── -->
    <record id="view_midvex_schema_template_form" model="ir.ui.view">
        <field name="name">midvex.schema.template.form</field>
        <field name="model">midvex.schema.template</field>
        <field name="arch" type="xml">
            <form string="Schema Template">
                <header>
                    <button string="Use This Template" name="action_use_template" type="object" class="btn-primary"/>
                    <button string="Duplicate Template" name="action_duplicate_template" type="object" class="btn-secondary"/>
                    <button string="Format JSON" name="action_format_json_fields" type="object" class="btn-secondary"/>
                    <button string="Validate JSON" name="action_validate_json_fields" type="object" class="btn-secondary"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="System Template"
                            bg_color="bg-info" invisible="not is_system_template"/>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="bg-danger" invisible="active"/>
                    <div class="alert alert-warning" role="alert" invisible="not is_system_template">
                        Duplicate this template before editing system templates.
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Template Name"/></h1>
                        <h2><field name="schema_type" placeholder="Schema Type, e.g. Product"/></h2>
                    </div>

                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="is_system_template"
                                   groups="base.group_system"/>
                            <field name="load_optional_fields_by_default"/>
                            <field name="required_field_count" readonly="1"/>
                            <field name="optional_field_count" readonly="1"/>
                        </group>
                        <group>
                            <field name="description" placeholder="Describe when to use this template…"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="JSON Template" name="json_template">
                            <div class="alert alert-info" role="alert">
                                This is the base JSON-LD structure. Required and optional fields are generated from the field lists.
                            </div>
                            <group string="Default JSON Structure">
                                <field name="json_template" nolabel="1"
                                       widget="text"
                                       class="o_midvex_json_editor o_midvex_json_editor_large"
                                       placeholder='{"@context":"https://schema.org","@type":"Product","name":"","url":""}'/>
                            </group>
                        </page>
                        <page string="Fields &amp; Mapping" name="fields_mapping">
                            <div class="alert alert-info" role="alert">
                                Use field keys such as name, url, brand.@id, offers.price, and publisher.logo.url. Dot-paths map values into nested JSON-LD objects.
                            </div>
                            <group>
                                <group string="Required Fields (JSON array)">
                                    <field name="required_fields_json" nolabel="1"
                                           widget="text"
                                           class="o_midvex_json_editor"
                                           placeholder='["name","description","image","url"]'/>
                                </group>
                                <group string="Optional Fields (JSON array)">
                                    <field name="optional_fields_json" nolabel="1"
                                           widget="text"
                                           class="o_midvex_json_editor"
                                           placeholder='["brand.@id","offers.price","offers.priceCurrency"]'/>
                                </group>
                            </group>
                            <group string="Auto-fill Mapping (JSON object)">
                                <field name="auto_mapping_json" nolabel="1"
                                       widget="text"
                                       class="o_midvex_json_editor"
                                       placeholder='{"name":"name","description":"description","url":"url"}'/>
                            </group>
                            <group string="Validation Rules (JSON object)">
                                <field name="validation_rules_json" nolabel="1"
                                       widget="text"
                                       class="o_midvex_json_editor"
                                       placeholder='{}'/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── List view ───────────────────────────────────────────────────── -->
    <record id="view_midvex_schema_template_list" model="ir.ui.view">
        <field name="name">midvex.schema.template.list</field>
        <field name="model">midvex.schema.template</field>
        <field name="arch" type="xml">
            <list string="Template Library" default_order="sequence">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="schema_type"/>
                <field name="description" optional="hide"/>
                <field name="required_field_count"/>
                <field name="is_system_template"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ── Kanban view ─────────────────────────────────────────────────── -->
    <record id="view_midvex_schema_template_kanban" model="ir.ui.view">
        <field name="name">midvex.schema.template.kanban</field>
        <field name="model">midvex.schema.template</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_order="sequence">
                <field name="name"/>
                <field name="schema_type"/>
                <field name="description"/>
                <field name="required_field_count"/>
                <field name="optional_field_count"/>
                <field name="is_system_template"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">
                            <div class="o_kanban_record_top">
                                <strong><field name="name"/></strong>
                                <span class="badge text-bg-info" t-if="record.is_system_template.raw_value">System</span>
                                <span class="badge text-bg-secondary" t-if="!record.is_system_template.raw_value">Custom</span>
                            </div>
                            <div class="text-muted mt-1">
                                <field name="schema_type"/>
                            </div>
                            <div class="mt-2">
                                <field name="description"/>
                            </div>
                            <div class="mt-2">
                                <span><field name="required_field_count"/> required</span>
                                <span class="ms-2"><field name="optional_field_count"/> optional</span>
                            </div>
                            <div class="mt-3">
                                <button name="action_use_template" type="object" string="Use This Template" class="btn btn-primary btn-sm"/>
                                <button name="action_duplicate_template" type="object" string="Duplicate" class="btn btn-secondary btn-sm ms-1"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ── Search view ─────────────────────────────────────────────────── -->
    <record id="view_midvex_schema_template_search" model="ir.ui.view">
        <field name="name">midvex.schema.template.search</field>
        <field name="model">midvex.schema.template</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="schema_type"/>
                <filter string="System Templates" name="system" domain="[('is_system_template','=',True)]"/>
                <filter string="Custom Templates" name="custom" domain="[('is_system_template','=',False)]"/>
                <filter string="Archived" name="inactive" domain="[('active','=',False)]"/>
                <separator/>
                <filter string="Product" name="product" domain="[('schema_type','=','Product')]"/>
                <filter string="FAQ" name="faq" domain="[('schema_type','=','FAQPage')]"/>
                <filter string="Breadcrumb" name="breadcrumb" domain="[('schema_type','=','BreadcrumbList')]"/>
                <filter string="Article / Blog" name="article_blog" domain="[('schema_type','in',('Article','BlogPosting'))]"/>
                <filter string="Page" name="page" domain="[('schema_type','not in',('Organization','WebSite'))]"/>
                <filter string="Service / Page Type" name="service_page_types" domain="[('schema_type','in',('Service','WebPage','ContactPage','AboutPage','CollectionPage'))]"/>
                <filter string="Global" name="global_types" domain="[('schema_type','in',('Organization','WebSite'))]"/>
                <filter string="Local Business" name="local_business" domain="[('schema_type','in',('LocalBusiness','ProfessionalService','MedicalBusiness','Dentist','Place','PostalAddress','OpeningHoursSpecification','GeoCoordinates','ContactPoint'))]"/>
                <filter string="Google Merchant" name="google_merchant" domain="[('name','ilike','Google Merchant')]"/>
                <separator/>
                <filter string="Schema Type" name="group_by_type" context="{'group_by':'schema_type'}"/>
            </search>
        </field>
    </record>

    <!-- ── Action ──────────────────────────────────────────────────────── -->
    <record id="action_midvex_schema_template" model="ir.actions.act_window">
        <field name="name">Template Library</field>
        <field name="res_model">midvex.schema.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No schema templates yet.
            </p>
            <p>Browse templates such as Product, FAQPage, BreadcrumbList, Article, Service and global Organization/WebSite schemas. Use a template to create a page schema with the template preselected.</p>
        </field>
    </record>

</odoo>
