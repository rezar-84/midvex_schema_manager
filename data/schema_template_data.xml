            <field name="json_template"><![CDATA[{
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "",
  "description": "",
  "url": "",
  "inLanguage": ""
}]]></field>
            <field name="required_fields_json"><![CDATA[["name", "url"]]]></field>
            <field name="optional_fields_json"><![CDATA[["description", "inLanguage"]]]></field>
            <field name="auto_mapping_json"><![CDATA[{"name": "name", "description": "description", "url": "url", "inLanguage": "inLanguage"}]]></field>
        </record>

        <!-- 10. AboutPage -->
        <record id="schema_template_aboutpage" model="midvex.schema.template">
            <field name="name">AboutPage</field>
            <field name="schema_type">AboutPage</field>
            <field name="sequence">10</field>
            <field name="is_system_template">True</field>
            <field name="load_optional_fields_by_default">True</field>
            <field name="active">True</field>
            <field name="description">Identifies an about/company page. Helps search engines understand the page purpose.</field>
            <field name="json_template"><![CDATA[{
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "",
  "description": "",
  "url": "",
  "inLanguage": ""
}]]></field>
            <field name="required_fields_json"><![CDATA[["name", "url"]]]></field>
            <field name="optional_fields_json"><![CDATA[["description", "inLanguage"]]]></field>
            <field name="auto_mapping_json"><![CDATA[{"name": "name", "description": "description", "url": "url", "inLanguage": "inLanguage"}]]></field>
        </record>

        <!-- 11. CollectionPage -->
        <record id="schema_template_collectionpage" model="midvex.schema.template">
            <field name="name">CollectionPage</field>
            <field name="schema_type">CollectionPage</field>
            <field name="sequence">11</field>
            <field name="is_system_template">True</field>
            <field name="active">True</field>
            <field name="description">Marks up a page that is a collection of items (e.g. category page, product listing).</field>
            <field name="json_template"><![CDATA[{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "",
  "description": "",
  "url": "",
  "hasPart": []
}]]></field>
            <field name="required_fields_json"><![CDATA[["name", "url"]]]></field>
            <field name="optional_fields_json"><![CDATA[["description", "hasPart", "inLanguage"]]]></field>
            <field name="auto_mapping_json"><![CDATA[{"name": "name", "description": "description", "url": "url", "inLanguage": "inLanguage"}]]></field>
        </record>

        <!-- 12. ItemList -->
        <record id="schema_template_itemlist" model="midvex.schema.template">
            <field name="name">ItemList</field>
            <field name="schema_type">ItemList</field>
            <field name="sequence">12</field>
            <field name="is_system_template">True</field>
            <field name="active">True</field>
            <field name="description">Marks up a list of items, e.g. for carousel rich results in Google.</field>
            <field name="json_template"><![CDATA[{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "",
  "description": "",
  "itemListElement": [],
  "numberOfItems": 0
}]]></field>
            <field name="required_fields_json"><![CDATA[["itemListElement"]]]></field>
            <field name="optional_fields_json"><![CDATA[["name", "description", "numberOfItems"]]]></field>
            <field name="auto_mapping_json"><![CDATA[{"name": "name", "description": "description", "url": "url"}]]></field>
        </record>

        <!-- 13. LocalBusiness -->
        <record id="schema_template_localbusiness" model="midvex.schema.template">
            <field name="name">LocalBusiness</field>
            <field name="schema_type">LocalBusiness</field>
            <field name="sequence">13</field>
            <field name="is_system_template">True</field>
            <field name="load_optional_fields_by_default">True</field>
            <field name="active">True</field>
            <field name="description">Local SEO schema for a physical business, including address, contact, opening hours and geo coordinates.</field>
            <field name="json_template"><![CDATA[{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "",
  "url": "",
  "telephone": "",
  "email": "",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "",
    "addressLocality": "",
    "addressRegion": "",
    "postalCode": "",
    "addressCountry": ""
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "",
    "longitude": ""
  },
  "openingHoursSpecification": [],
  "sameAs": []
}]]></field>
            <field name="required_fields_json"><![CDATA[["name", "url"]]]></field>
            <field name="optional_fields_json"><![CDATA[["telephone", "email", "address.streetAddress", "address.addressLocality", "address.addressRegion", "address.postalCode", "address.addressCountry", "geo.latitude", "geo.longitude", "openingHoursSpecification", "sameAs"]]]></field>
            <field name="auto_mapping_json"><![CDATA[{"name": "name", "url": "url"}]]></field>
        </record>

        <!-- 14. ProfessionalService -->
        <record id="schema_template_professionalservice" model="midvex.schema.template">
            <field name="name">ProfessionalService</field>
            <field name="schema_type">ProfessionalService</field>
            <field name="sequence">14</field>
            <field name="is_system_template">True</field>
            <field name="load_optional_fields_by_default">True</field>
            <field name="active">True</field>
            <field name="description">Local business schema for professional service providers.</field>
            <field name="json_template"><![CDATA[{
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "",
  "description": "",
  "url": "",
  "telephone": "",
  "address": {
    "@type": "PostalAddress"
  },
  "areaServed": ""
}]]></field>
            <field name="required_fields_json"><![CDATA[["name", "url"]]]></field>
            <field name="optional_fields_json"><![CDATA[["description", "telephone", "address.streetAddress", "address.addressLocality", "address.addressCountry", "areaServed"]]]></field>
            <field name="auto_mapping_json"><![CDATA[{"name": "name", "description": "description", "url": "url"}]]></field>
        </record>

        <!-- 15. Place -->
        <record id="schema_template_place" model="midvex.schema.template">
            <field name="name">Place</field>
            <field name="schema_type">Place</field>
            <field name="sequence">15</field>
            <field name="is_system_template">True</field>
            <field name="active">True</field>
            <field name="description">Describes a physical place with address and geo coordinates.</field>
            <field name="json_template"><![CDATA[{
  "@context": "https://schema.org",
  "@type": "Place",
  "name": "",
  "address": {
    "@type": "PostalAddress"
  },
  "geo": {
    "@type": "GeoCoordinates"
  }
}]]></field>
            <field name="required_fields_json"><![CDATA[["name"]]]></field>
            <field name="optional_fields_json"><![CDATA[["address.streetAddress", "address.addressLocality", "address.addressCountry", "geo.latitude", "geo.longitude"]]]></field>
            <field name="auto_mapping_json"><![CDATA[{"name": "name"}]]></field>
        </record>

        <!-- 16. Google Merchant Product Schema -->
        <record id="schema_template_google_merchant_product" model="midvex.schema.template">
            <field name="name">Google Merchant Product Schema</field>
            <field name="schema_type">Product</field>
            <field name="sequence">16</field>
            <field name="is_system_template">True</field>
            <field name="load_optional_fields_by_default">True</field>
            <field name="active">True</field>
            <field name="description">Product schema checklist template for Google Merchant readiness. Price remains optional unless real commerce data is available.</field>
            <field name="json_template"><![CDATA[{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "",
  "description": "",
  "image": "",
  "url": "",
  "sku": "",
  "category": "",
  "brand": {
    "@id": ""
  },
  "offers": {
    "@type": "Offer",
    "url": "",
    "availability": "https://schema.org/LimitedAvailability",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "priceCurrency": "",
      "description": "Price available upon request."
    }
  }
}]]></field>
            <field name="required_fields_json"><![CDATA[["name", "description", "image"]]]></field>
            <field name="optional_fields_json"><![CDATA[["url", "sku", "category", "brand.@id", "manufacturer.@id", "offers.url", "offers.availability", "offers.priceSpecification.priceCurrency", "offers.priceSpecification.description"]]]></field>
            <field name="auto_mapping_json"><![CDATA[{"name": "name", "description": "description", "image": "image", "url": "url"}]]></field>
        </record>

