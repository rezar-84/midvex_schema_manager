<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- 1. Organization -->
        <record id="schema_template_organization" model="midvex.schema.template">
            <field name="name">Organization</field>
            <field name="schema_type">Organization</field>
            <field name="sequence">1</field>
            <field name="is_system_template">True</field>
            <field name="load_optional_fields_by_default">True</field>
            <field name="active">True</field>
            <field name="description">Identifies the organization behind the website. Recommended on every site.</field>
            <field name="json_template"><![CDATA[{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "",
  "legalName": "",
  "url": "",
  "logo": "",
  "email": "",
  "telephone": "",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "",
    "addressLocality": "",
    "addressRegion": "",
    "postalCode": "",
    "addressCountry": ""
  },
  "sameAs": []
}]]></field>
            <field name="required_fields_json"><![CDATA[["name", "url"]]]></field>
            <field name="optional_fields_json"><![CDATA[["legalName", "logo", "email", "telephone", "address", "sameAs"]]]></field>
            <field name="auto_mapping_json"><![CDATA[{"name": "name", "url": "url"}]]></field>
        </record>

        <!-- 2. WebSite -->
        <record id="schema_template_website" model="midvex.schema.template">
            <field name="name">WebSite</field>
            <field name="schema_type">WebSite</field>
            <field name="sequence">2</field>
            <field name="is_system_template">True</field>
            <field name="load_optional_fields_by_default">True</field>
            <field name="active">True</field>
            <field name="description">Identifies the website. Used to enable the Sitelinks Searchbox in Google.</field>
            <field name="json_template"><![CDATA[{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "",
  "url": "",
  "inLanguage": []
}]]></field>
            <field name="required_fields_json"><![CDATA[["name", "url"]]]></field>
            <field name="optional_fields_json"><![CDATA[["inLanguage", "potentialAction"]]]></field>
            <field name="auto_mapping_json"><![CDATA[{"name": "name", "url": "url", "inLanguage": "inLanguage"}]]></field>
        </record>

        <!-- 3. Product -->
        <record id="schema_template_product" model="midvex.schema.template">
            <field name="name">Product</field>
            <field name="schema_type">Product</field>
            <field name="sequence">3</field>
            <field name="is_system_template">True</field>
            <field name="load_optional_fields_by_default">True</field>
            <field name="active">True</field>
            <field name="description">Describes a product. B2B-safe by default with quote-based offer fields and no fake price requirement.</field>
            <field name="json_template"><![CDATA[{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "",
  "description": "",
  "image": "",
  "url": "",
  "sku": "",
  "category": "",
  "brand": {
    "@id": ""
  },
  "manufacturer": {
    "@id": ""
  },
  "offers": {
    "@type": "Offer",
    "url": "",
    "availability": "https://schema.org/LimitedAvailability",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "priceCurrency": "",
      "description": "Price available upon request."
    }
  }
}]]></field>
            <field name="required_fields_json"><![CDATA[["name", "description", "image"]]]></field>
            <field name="optional_fields_json"><![CDATA[["url", "sku", "category", "brand.@id", "manufacturer.@id", "offers.url", "offers.availability", "offers.priceSpecification.priceCurrency", "offers.priceSpecification.description"]]]></field>
            <field name="auto_mapping_json"><![CDATA[{"name": "name", "description": "description", "image": "image", "url": "url", "brand.@id": "brand.@id", "manufacturer.@id": "manufacturer.@id"}]]></field>
        </record>

        <!-- 4. FAQPage -->
        <record id="schema_template_faqpage" model="midvex.schema.template">
            <field name="name">FAQPage</field>
            <field name="schema_type">FAQPage</field>
            <field name="sequence">4</field>
            <field name="is_system_template">True</field>
            <field name="active">True</field>
            <field name="description">Marks up a FAQ page. Questions and answers are added via the FAQ Items tab. Only add if the same content is visible on the page.</field>
            <field name="json_template"><![CDATA[{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": []
}]]></field>
            <field name="required_fields_json"><![CDATA[["mainEntity"]]]></field>
            <field name="optional_fields_json"><![CDATA[[]]]></field>
            <field name="auto_mapping_json"><![CDATA[{"name": "name", "url": "url"}]]></field>
        </record>

        <!-- 5. BreadcrumbList -->
        <record id="schema_template_breadcrumblist" model="midvex.schema.template">
            <field name="name">BreadcrumbList</field>
            <field name="schema_type">BreadcrumbList</field>
            <field name="sequence">5</field>
            <field name="is_system_template">True</field>
            <field name="active">True</field>
            <field name="description">Defines the breadcrumb trail for a page. Items are added via the Breadcrumb Items tab.</field>
            <field name="json_template"><![CDATA[{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": []
}]]></field>
            <field name="required_fields_json"><![CDATA[["itemListElement"]]]></field>
            <field name="optional_fields_json"><![CDATA[[]]]></field>
            <field name="auto_mapping_json"><![CDATA[{}]]></field>
        </record>

        <!-- 6. Article -->
        <record id="schema_template_article" model="midvex.schema.template">
            <field name="name">Article</field>
            <field name="schema_type">Article</field>
            <field name="sequence">6</field>
            <field name="is_system_template">True</field>
            <field name="load_optional_fields_by_default">True</field>
            <field name="active">True</field>
            <field name="description">Marks up a news or editorial article. Enables rich results in Google News and Discover.</field>
            <field name="json_template"><![CDATA[{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "",
  "description": "",
  "image": "",
  "author": {
    "@type": "Person",
    "name": ""
  },
  "publisher": {
    "@type": "Organization",
    "name": "",
    "logo": {
      "@type": "ImageObject",
      "url": ""
    }
  },
  "datePublished": "",
  "dateModified": "",
  "url": "",
  "inLanguage": ""
}]]></field>
            <field name="required_fields_json"><![CDATA[["headline", "image", "author", "publisher", "datePublished"]]]></field>
            <field name="optional_fields_json"><![CDATA[["description", "dateModified", "url", "inLanguage"]]]></field>
            <field name="auto_mapping_json"><![CDATA[{"headline": "name", "description": "description", "image": "image", "url": "url", "inLanguage": "inLanguage"}]]></field>
        </record>

        <!-- 7. BlogPosting -->
        <record id="schema_template_blogposting" model="midvex.schema.template">
            <field name="name">BlogPosting</field>
            <field name="schema_type">BlogPosting</field>
            <field name="sequence">7</field>
            <field name="is_system_template">True</field>
            <field name="load_optional_fields_by_default">True</field>
            <field name="active">True</field>
            <field name="description">Marks up a blog post. Sub-type of Article, optimised for blogs.</field>
            <field name="json_template"><![CDATA[{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "",
  "description": "",
  "image": "",
  "author": {
    "@type": "Person",
    "name": ""
  },
  "publisher": {
    "@type": "Organization",
    "name": ""
  },
  "datePublished": "",
  "dateModified": "",
  "url": "",
  "inLanguage": ""
}]]></field>
            <field name="required_fields_json"><![CDATA[["headline", "author", "datePublished"]]]></field>
            <field name="optional_fields_json"><![CDATA[["description", "image", "publisher", "dateModified", "url", "inLanguage"]]]></field>
            <field name="auto_mapping_json"><![CDATA[{"headline": "name", "description": "description", "image": "image", "url": "url", "inLanguage": "inLanguage"}]]></field>
        </record>

        <!-- 8. Service -->
        <record id="schema_template_service" model="midvex.schema.template">
            <field name="name">Service</field>
            <field name="schema_type">Service</field>
            <field name="sequence">8</field>
            <field name="is_system_template">True</field>
            <field name="load_optional_fields_by_default">True</field>
            <field name="active">True</field>
            <field name="description">Describes a service offered by the organization.</field>
            <field name="json_template"><![CDATA[{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "",
  "description": "",
  "provider": {
    "@type": "Organization",
    "name": ""
  },
  "serviceType": "",
  "url": "",
  "image": "",
  "areaServed": ""
}]]></field>
            <field name="required_fields_json"><![CDATA[["name", "description", "provider"]]]></field>
            <field name="optional_fields_json"><![CDATA[["serviceType", "url", "image", "areaServed"]]]></field>
            <field name="auto_mapping_json"><![CDATA[{"name": "name", "description": "description", "image": "image", "url": "url"}]]></field>
        </record>

        <!-- 9. ContactPage -->
        <record id="schema_template_contactpage" model="midvex.schema.template">
            <field name="name">ContactPage</field>
            <field name="schema_type">ContactPage</field>
            <field name="sequence">9</field>
            <field name="is_system_template">True</field>
            <field name="load_optional_fields_by_default">True</field>
