<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Odoo 19 res.groups fields (verified from source):
          name        — Char, required
          user_ids    — Many2many res.users  (was 'users' in Odoo 16 and earlier)
          implied_ids — Many2many res.groups (still exists in Odoo 19)
          privilege_id— Many2one res.groups.privilege (replaces 'category_id')
        Removed in Odoo 17-19: category_id, users (renamed), website publisher groups
    -->
    <data>
        <!-- Read-only access to all midvex.schema.* models -->
        <record id="group_midvex_schema_user" model="res.groups">
            <field name="name">Schema User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Full CRUD access; admin is added automatically -->
        <record id="group_midvex_schema_manager" model="res.groups">
            <field name="name">Schema Manager</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('midvex_schema_manager.group_midvex_schema_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
