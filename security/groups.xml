<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Read-only access to all midvex.schema.* models -->
        <record id="group_midvex_schema_user" model="res.groups">
            <field name="name">Schema User</field>
        </record>

        <!-- Full CRUD access; admin is added automatically -->
        <record id="group_midvex_schema_manager" model="res.groups">
            <field name="name">Schema Manager</field>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
